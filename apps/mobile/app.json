{
  "name": "DontLetMeForget",
  "slug": "dontletmeforget",
  "version": "0.1.0",
  "orientation": "portrait",
  "icon": "./assets/icon.png",
  "userInterfaceStyle": "automatic",
  "splash": {
    "image": "./assets/splash.png",
    "resizeMode": "contain",
    "backgroundColor": "#ffffff"
  },
  "assetBundlePatterns": [
    "**/*"
  ],
  "ios": {
    "supportsTabletMode": true,
    "bundleIdentifier": "com.614restore.dontletmeforget",
    "buildNumber": "1",
    "infoPlist": {
      "NSMicrophoneUsageDescription": "We need microphone access to record your voice for item logging.",
      "NSPhotoLibraryUsageDescription": "We need access to your photos to capture item images.",
      "NSCameraUsageDescription": "We need camera access to capture photos of items.",
      "NSLocalNetworkUsageDescription": "We use local network discovery for household sync.",
      "NSBonjourServices": [
        "_dontletmeforget._tcp"
      ]
    },
    "infoPlistUpdates": {
      "NSFaceIDUsageDescription": "We need Face ID to secure your private vault."
    }
  },
  "android": {
    "adaptiveIcon": {
      "foregroundImage": "./assets/adaptive-icon.png",
      "backgroundColor": "#ffffff"
    },
    "package": "com.restore614.dontletmeforget",
    "intentFilters": [
      {
        "action": "android.intent.action.MAIN",
        "category": [
          "android.intent.category.LAUNCHER"
        ]
      }
    ],
    "permissions": [
      "android.permission.RECORD_AUDIO",
      "android.permission.CAMERA",
      "android.permission.READ_EXTERNAL_STORAGE",
      "android.permission.WRITE_EXTERNAL_STORAGE",
      "android.permission.ACCESS_FINE_LOCATION",
      "android.permission.INTERNET"
    ]
  },
  "web": {
    "favicon": "./assets/favicon.png"
  },
  "plugins": [
    [
      "expo-camera",
      {
        "cameraPermission": "Allow DontLetMeForget to access your camera."
      }
    ],
    [
      "expo-av",
      {
        "microphonePermission": "Allow DontLetMeForget to access your microphone."
      }
    ],
    [
      "expo-file-system"
    ],
    [
      "expo-local-authentication"
    ]
  ],
  "extra": {
    "eas": {
      "projectId": "your_project_id_here",
      "build": {
        "development": {
          "developmentClient": true,
          "distribution": "internal"
        },
        "preview": {
          "distribution": "internal"
        },
        "production": {}
      },
      "submit": {
        "production": {}
      }
    },
    "supabase": {
      "url": "your_supabase_url",
      "anonKey": "your_anon_key"
    }
  },
  "owner": "614restore"
}
